<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PromptCraft — Grammarly for Prompting</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink: #0f0e0d;
    --ink2: #3a3835;
    --ink3: #7a7673;
    --paper: #faf8f4;
    --paper2: #f2efe9;
    --paper3: #e8e3da;
    --accent: #c8522a;
    --accent2: #e8936a;
    --accent-light: #fdf0ea;
    --green: #2a6b4a;
    --green-light: #eaf4ee;
    --amber: #b07020;
    --amber-light: #fdf5e6;
    --blue: #1e5080;
    --blue-light: #eaf2fa;
    --red: #b03030;
    --red-light: #fbeaea;
    --border: rgba(15,14,13,0.1);
    --border2: rgba(15,14,13,0.06);
    --shadow: 0 1px 3px rgba(15,14,13,0.08), 0 4px 16px rgba(15,14,13,0.06);
    --shadow-lg: 0 8px 32px rgba(15,14,13,0.12);
    --radius: 12px;
    --radius-sm: 8px;
    --radius-xs: 5px;
    --font-display: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, sans-serif;
  }

  html { font-size: 16px; }
  body {
    font-family: var(--font-body);
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
    line-height: 1.6;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(250,248,244,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border2);
    padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 58px;
  }
  .logo {
    display: flex; align-items: baseline; gap: 6px;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
  }
  .logo-dot { color: var(--accent); }
  .nav-pill {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: var(--accent-light);
    color: var(--accent);
    padding: 4px 10px;
    border-radius: 20px;
  }

  /* HERO */
  .hero {
    text-align: center;
    padding: 3rem 2rem 2rem;
    max-width: 600px;
    margin: 0 auto;
  }
  .hero-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-bottom: 0.75rem;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--accent);
  }
  .hero p {
    font-size: 0.95rem;
    color: var(--ink3);
    font-weight: 300;
    max-width: 420px;
    margin: 0 auto;
  }

  /* MAIN LAYOUT */
  .app {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 2rem 4rem;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.5rem;
    align-items: start;
  }

  /* LEFT PANEL */
  .editor-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .card-header {
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--border2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .card-title {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .char-count {
    font-size: 0.75rem;
    color: var(--ink3);
    font-variant-numeric: tabular-nums;
  }

  #prompt-input {
    width: 100%;
    border: none;
    outline: none;
    resize: none;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    color: var(--ink);
    background: transparent;
    padding: 1.25rem;
    min-height: 160px;
    line-height: 1.7;
    display: block;
  }
  #prompt-input::placeholder { color: var(--ink3); font-style: italic; }

  /* EXAMPLES STRIP */
  .examples-row {
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--border2);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .examples-label {
    font-size: 0.72rem;
    color: var(--ink3);
    font-weight: 500;
    margin-right: 0.25rem;
  }
  .example-chip {
    font-size: 0.72rem;
    font-weight: 400;
    background: var(--paper2);
    color: var(--ink2);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 3px 10px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .example-chip:hover {
    background: var(--paper3);
    color: var(--ink);
  }

  /* ANALYZE BUTTON */
  .btn-analyze {
    width: 100%;
    padding: 1rem 1.5rem;
    background: var(--ink);
    color: white;
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    letter-spacing: 0.01em;
  }
  .btn-analyze:hover:not(:disabled) {
    background: var(--accent);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(200,82,42,0.3);
  }
  .btn-analyze:active:not(:disabled) { transform: translateY(0); }
  .btn-analyze:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .btn-icon { font-size: 1rem; }

  /* LOADING */
  @keyframes pulse-bar {
    0%, 100% { opacity: 0.4; transform: scaleX(0.3); }
    50% { opacity: 1; transform: scaleX(1); }
  }
  .loading-bar {
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 1px;
    animation: pulse-bar 1.5s ease-in-out infinite;
    transform-origin: left;
  }

  /* OUTPUT CARD */
  .output-card {
    display: none;
    animation: fadeSlideUp 0.4s ease;
  }
  .output-card.visible { display: block; }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .output-body { padding: 1.25rem; }

  .improved-prompt {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--ink);
    font-weight: 300;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 1rem 1.1rem;
    position: relative;
  }

  .output-actions {
    display: flex;
    gap: 0.6rem;
    margin-top: 1rem;
  }
  .btn-sm {
    font-size: 0.78rem;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: var(--radius-xs);
    border: 1px solid var(--border);
    background: white;
    color: var(--ink2);
    cursor: pointer;
    transition: all 0.15s;
    font-family: var(--font-body);
  }
  .btn-sm:hover { background: var(--paper2); }
  .btn-sm.primary {
    background: var(--ink);
    color: white;
    border-color: transparent;
  }
  .btn-sm.primary:hover { background: var(--accent); }

  /* RIGHT PANEL — SIDEBAR */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 74px;
  }

  /* SCORE CARD */
  .score-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.25rem;
  }
  .score-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-bottom: 0.75rem;
  }
  .score-display {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 0.75rem;
  }
  .score-number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    color: var(--ink);
    transition: all 0.6s ease;
  }
  .score-max { font-size: 1rem; color: var(--ink3); }
  .score-bar-track {
    height: 6px;
    background: var(--paper3);
    border-radius: 3px;
    overflow: hidden;
  }
  .score-bar-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    width: 0%;
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .score-verdict {
    font-size: 0.78rem;
    color: var(--ink3);
    margin-top: 0.5rem;
    font-style: italic;
  }

  /* SUGGESTIONS */
  .suggestions-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .suggestions-header {
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--border2);
  }
  .suggestions-title {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink3);
  }

  .suggestion-list { padding: 0.5rem; }

  .suggestion-item {
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    margin-bottom: 0.4rem;
    border: 1px solid transparent;
    animation: fadeSlideUp 0.3s ease both;
  }
  .suggestion-item:last-child { margin-bottom: 0; }

  .suggestion-item.clarity   { background: var(--blue-light);  border-color: rgba(30,80,128,0.12); }
  .suggestion-item.specificity { background: var(--amber-light); border-color: rgba(176,112,32,0.12); }
  .suggestion-item.structure { background: var(--green-light);  border-color: rgba(42,107,74,0.12); }
  .suggestion-item.context   { background: var(--accent-light); border-color: rgba(200,82,42,0.12); }
  .suggestion-item.depth     { background: var(--green-light);  border-color: rgba(42,107,74,0.12); }
  .suggestion-item.tone      { background: var(--blue-light);   border-color: rgba(30,80,128,0.12); }

  .suggestion-tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 20px;
    margin-bottom: 0.4rem;
  }
  .clarity   .suggestion-tag { background: rgba(30,80,128,0.15);  color: var(--blue); }
  .specificity .suggestion-tag { background: rgba(176,112,32,0.15); color: var(--amber); }
  .structure .suggestion-tag { background: rgba(42,107,74,0.15);  color: var(--green); }
  .context   .suggestion-tag { background: rgba(200,82,42,0.15);  color: var(--accent); }
  .depth     .suggestion-tag { background: rgba(42,107,74,0.15);  color: var(--green); }
  .tone      .suggestion-tag { background: rgba(30,80,128,0.15);  color: var(--blue); }

  .suggestion-before {
    font-size: 0.78rem;
    color: var(--red);
    text-decoration: line-through;
    margin-bottom: 0.2rem;
    display: flex;
    align-items: flex-start;
    gap: 5px;
  }
  .suggestion-after {
    font-size: 0.78rem;
    color: var(--green);
    display: flex;
    align-items: flex-start;
    gap: 5px;
  }
  .suggestion-text {
    font-size: 0.8rem;
    color: var(--ink2);
    margin-top: 0.35rem;
    line-height: 1.5;
  }

  .empty-state {
    padding: 2rem 1.25rem;
    text-align: center;
    color: var(--ink3);
    font-size: 0.85rem;
    font-style: italic;
  }
  .empty-icon { font-size: 1.5rem; margin-bottom: 0.5rem; opacity: 0.5; }

  /* TONE SELECTOR */
  .tone-row {
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border2);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .tone-label {
    font-size: 0.72rem;
    color: var(--ink3);
    font-weight: 500;
  }
  .tone-btn {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--paper);
    color: var(--ink2);
    cursor: pointer;
    transition: all 0.15s;
    font-family: var(--font-body);
  }
  .tone-btn.active {
    background: var(--ink);
    color: white;
    border-color: transparent;
  }
  .tone-btn:hover:not(.active) { background: var(--paper3); }

  /* ERROR */
  .error-msg {
    background: var(--red-light);
    border: 1px solid rgba(176,48,48,0.2);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    font-size: 0.82rem;
    color: var(--red);
    display: none;
  }
  .error-msg.visible { display: block; }

  /* FOOTER */
  .footer-note {
    text-align: center;
    padding: 1rem;
    font-size: 0.72rem;
    color: var(--ink3);
  }

  @media (max-width: 768px) {
    .app { grid-template-columns: 1fr; }
    .sidebar { position: static; }
    nav { padding: 0 1rem; }
    .hero { padding: 2rem 1rem 1.5rem; }
    .app { padding: 1rem 1rem 3rem; }
  }
</style>
</head>
<body>

<nav>
  <a class="logo" href="#">PromptCraft<span class="logo-dot">.</span></a>
  <span class="nav-pill">✦ No login needed</span>
</nav>

<div class="hero">
  <p class="hero-label">✦ AI Prompt Optimizer</p>
  <h1>Write prompts that <em>actually</em> work.</h1>
  <p>Type any rough idea. Get a structured, powerful prompt — with expert feedback explaining every improvement.</p>
</div>

<div class="app">

  <!-- LEFT: EDITOR -->
  <div class="editor-panel">

    <!-- INPUT CARD -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Your Prompt</span>
        <span class="char-count" id="char-count">0 characters</span>
      </div>
      <textarea id="prompt-input" placeholder="Type your rough prompt here… e.g. 'tell me about bitcoin'" rows="6"></textarea>
      <div class="examples-row">
        <span class="examples-label">Try:</span>
        <span class="example-chip" onclick="setExample('tell me about bitcoin')">tell me about bitcoin</span>
        <span class="example-chip" onclick="setExample('help me study linux')">help me study linux</span>
        <span class="example-chip" onclick="setExample('give me gym plan')">give me gym plan</span>
        <span class="example-chip" onclick="setExample('explain ai')">explain ai</span>
      </div>
    </div>

    <!-- TONE SELECTOR -->
    <div class="card" style="overflow:visible">
      <div class="tone-row">
        <span class="tone-label">Tone:</span>
        <button class="tone-btn active" data-tone="balanced" onclick="setTone(this)">Balanced</button>
        <button class="tone-btn" data-tone="technical" onclick="setTone(this)">Technical</button>
        <button class="tone-btn" data-tone="beginner-friendly" onclick="setTone(this)">Beginner</button>
        <button class="tone-btn" data-tone="creative" onclick="setTone(this)">Creative</button>
        <button class="tone-btn" data-tone="academic" onclick="setTone(this)">Academic</button>
      </div>
    </div>

    <!-- ANALYZE BUTTON -->
    <button class="btn-analyze" id="analyze-btn" onclick="analyzePrompt()">
      <span class="btn-icon">⚡</span>
      <span id="btn-text">Improve My Prompt</span>
    </button>

    <div class="error-msg" id="error-msg"></div>

    <!-- OUTPUT CARD -->
    <div class="card output-card" id="output-card">
      <div class="card-header">
        <span class="card-title">✦ Improved Prompt</span>
        <span id="output-score-badge" style="font-size:0.72rem;font-weight:500;background:var(--green-light);color:var(--green);padding:3px 9px;border-radius:20px;"></span>
      </div>
      <div id="loading-bar" class="loading-bar" style="display:none;margin:0 1.25rem;border-radius:1px;"></div>
      <div class="output-body">
        <div class="improved-prompt" id="improved-prompt-text"></div>
        <div class="output-actions">
          <button class="btn-sm primary" onclick="copyImproved()">Copy prompt</button>
          <button class="btn-sm" onclick="useImproved()">Use as input ↻</button>
          <button class="btn-sm" onclick="clearAll()">Clear</button>
        </div>
      </div>
    </div>

  </div>

  <!-- RIGHT: SIDEBAR -->
  <div class="sidebar">

    <!-- SCORE -->
    <div class="score-card">
      <div class="score-label">Prompt quality score</div>
      <div class="score-display">
        <span class="score-number" id="score-number">—</span>
        <span class="score-max" id="score-max"></span>
      </div>
      <div class="score-bar-track">
        <div class="score-bar-fill" id="score-bar"></div>
      </div>
      <div class="score-verdict" id="score-verdict">Analyze a prompt to see your score</div>
    </div>

    <!-- SUGGESTIONS -->
    <div class="suggestions-card">
      <div class="suggestions-header">
        <div class="suggestions-title">Feedback & Improvements</div>
      </div>
      <div class="suggestion-list" id="suggestion-list">
        <div class="empty-state">
          <div class="empty-icon">💡</div>
          Suggestions will appear here after analysis
        </div>
      </div>
    </div>

  </div>
</div>

<div class="footer-note">PromptCraft · Powered by Claude AI · Your prompt is sent to the Anthropic API and not stored</div>

<script>
let selectedTone = 'balanced';
let lastImproved = '';

const input = document.getElementById('prompt-input');
const charCount = document.getElementById('char-count');

input.addEventListener('input', () => {
  const n = input.value.length;
  charCount.textContent = n + ' character' + (n !== 1 ? 's' : '');
});

function setExample(text) {
  input.value = text;
  charCount.textContent = text.length + ' characters';
  input.focus();
}

function setTone(btn) {
  document.querySelectorAll('.tone-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  selectedTone = btn.dataset.tone;
}

function getVerdict(score) {
  if (score >= 85) return 'Excellent — highly structured and specific';
  if (score >= 70) return 'Good — clear improvements applied';
  if (score >= 50) return 'Fair — several key elements added';
  return 'Weak start — significant improvement made';
}

function getScoreColor(score) {
  if (score >= 80) return 'var(--green)';
  if (score >= 60) return 'var(--amber)';
  return 'var(--accent)';
}

function renderSuggestions(suggestions) {
  const list = document.getElementById('suggestion-list');
  if (!suggestions || suggestions.length === 0) {
    list.innerHTML = '<div class="empty-state"><div class="empty-icon">✓</div>Prompt looks great already!</div>';
    return;
  }

  list.innerHTML = suggestions.map((s, i) => `
    <div class="suggestion-item ${(s.category || 'clarity').toLowerCase()}" style="animation-delay:${i * 0.07}s">
      <div class="suggestion-tag">${s.category || 'Tip'}</div>
      <div class="suggestion-before">❌ ${s.before || 'Original issue'}</div>
      <div class="suggestion-after">✅ ${s.after || s.fix || 'Improvement applied'}</div>
      ${s.explanation ? `<div class="suggestion-text">${s.explanation}</div>` : ''}
    </div>
  `).join('');
}

async function analyzePrompt() {
  const promptText = input.value.trim();
  if (!promptText) {
    showError('Please enter a prompt first.');
    return;
  }

  const btn = document.getElementById('analyze-btn');
  const btnText = document.getElementById('btn-text');
  const outputCard = document.getElementById('output-card');
  const errorMsg = document.getElementById('error-msg');
  const loadingBar = document.getElementById('loading-bar');

  // Reset
  errorMsg.classList.remove('visible');
  btn.disabled = true;
  btnText.textContent = 'Analyzing…';
  outputCard.classList.remove('visible');

  const systemPrompt = `You are an expert AI prompt engineer. Your job is to take a rough, vague, or weak prompt and transform it into a highly structured, specific, and powerful prompt.

Always respond with ONLY valid JSON in this exact format (no markdown, no explanation outside JSON):
{
  "improved_prompt": "The full improved prompt text here",
  "score": 82,
  "suggestions": [
    {
      "category": "Specificity",
      "before": "Too vague — no target audience",
      "after": "Added 'for a beginner' to set the right level",
      "explanation": "Specifying the audience helps the AI calibrate complexity and vocabulary."
    },
    {
      "category": "Structure",
      "before": "No output format defined",
      "after": "Added clear sections: definition, types, examples",
      "explanation": "Asking for structured sections produces more organized, scannable answers."
    }
  ]
}

Rules:
- The score (0-100) represents the ORIGINAL prompt's quality BEFORE improvement (so weak prompts score 20-40, decent ones 50-70)
- Always add a role ("You are a...") at the start of the improved prompt
- Make the improved prompt ${selectedTone === 'balanced' ? 'clear and well-structured' : selectedTone === 'technical' ? 'technical and precise, using domain terminology' : selectedTone === 'beginner-friendly' ? 'simple and approachable for complete beginners' : selectedTone === 'creative' ? 'imaginative and open-ended, encouraging creative output' : 'formal and academically rigorous'}
- Provide 3-4 specific suggestions showing exactly what was wrong and what was fixed
- Valid categories: Clarity, Specificity, Structure, Context, Depth, Tone
- Return ONLY the JSON object. No preamble, no code blocks, no explanation.`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: 'user', content: `Improve this prompt: "${promptText}"` }]
      })
    });

    if (!response.ok) {
      const err = await response.json();
      throw new Error(err.error?.message || 'API request failed');
    }

    const data = await response.json();
    const rawText = data.content?.[0]?.text || '';

    // Parse JSON — strip any accidental markdown fences
    let parsed;
    try {
      const clean = rawText.replace(/```json|```/g, '').trim();
      parsed = JSON.parse(clean);
    } catch (e) {
      throw new Error('Could not parse AI response. Please try again.');
    }

    // Render output
    lastImproved = parsed.improved_prompt || '';
    document.getElementById('improved-prompt-text').textContent = lastImproved;
    outputCard.classList.add('visible');

    // Score
    const score = Math.min(100, Math.max(0, Math.round(parsed.score || 50)));
    const scoreEl = document.getElementById('score-number');
    const scoreMax = document.getElementById('score-max');
    const scoreBar = document.getElementById('score-bar');
    const scoreVerdict = document.getElementById('score-verdict');
    const scoreBadge = document.getElementById('output-score-badge');

    scoreEl.textContent = score;
    scoreEl.style.color = getScoreColor(score);
    scoreMax.textContent = '/ 100';
    scoreVerdict.textContent = getVerdict(score);
    scoreBadge.textContent = `Score: ${score}/100`;

    setTimeout(() => {
      scoreBar.style.width = score + '%';
    }, 100);

    // Suggestions
    renderSuggestions(parsed.suggestions);

  } catch (err) {
    showError('Error: ' + err.message);
  } finally {
    btn.disabled = false;
    btnText.textContent = 'Improve My Prompt';
    loadingBar.style.display = 'none';
  }
}

function showError(msg) {
  const errorMsg = document.getElementById('error-msg');
  errorMsg.textContent = msg;
  errorMsg.classList.add('visible');
}

function copyImproved() {
  if (!lastImproved) return;
  navigator.clipboard.writeText(lastImproved).then(() => {
    const btn = event.target;
    btn.textContent = 'Copied! ✓';
    setTimeout(() => btn.textContent = 'Copy prompt', 1800);
  });
}

function useImproved() {
  if (!lastImproved) return;
  input.value = lastImproved;
  charCount.textContent = lastImproved.length + ' characters';
  document.getElementById('output-card').classList.remove('visible');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function clearAll() {
  input.value = '';
  charCount.textContent = '0 characters';
  document.getElementById('output-card').classList.remove('visible');
  document.getElementById('score-number').textContent = '—';
  document.getElementById('score-max').textContent = '';
  document.getElementById('score-bar').style.width = '0%';
  document.getElementById('score-verdict').textContent = 'Analyze a prompt to see your score';
  document.getElementById('output-score-badge').textContent = '';
  document.getElementById('suggestion-list').innerHTML = '<div class="empty-state"><div class="empty-icon">💡</div>Suggestions will appear here after analysis</div>';
  document.getElementById('error-msg').classList.remove('visible');
  lastImproved = '';
}

// Allow Ctrl+Enter to analyze
input.addEventListener('keydown', (e) => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') analyzePrompt();
});
</script>
</body>
</html>
